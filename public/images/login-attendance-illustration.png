<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 500" width="100%" height="100%">
  <!-- Definitions for gradients and shadows -->
  <defs>
    <linearGradient id="skyline-grad-fallback" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#E2EDFD" stop-opacity="0.2"/>
      <stop offset="100%" stop-color="#D6E5FC" stop-opacity="0.6"/>
    </linearGradient>
    <linearGradient id="phone-screen-fallback" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FFFFFF" />
      <stop offset="100%" stop-color="#F3F8FF" />
    </linearGradient>
    <filter id="soft-shadow-fallback" x="-10%" y="-10%" width="130%" height="130%">
      <drop-shadow dx="0" dy="12" stdDeviation="15" flood-color="#0F1F3D" flood-opacity="0.08" />
    </filter>
    <filter id="icon-shadow-fallback" x="-20%" y="-20%" width="140%" height="140%">
      <drop-shadow dx="0" dy="4" stdDeviation="6" flood-color="#0F1F3D" flood-opacity="0.06" />
    </filter>
  </defs>

  <!-- Background Grid -->
  <g opacity="0.4">
    <circle cx="280" cy="270" r="180" fill="none" stroke="#3B82F6" stroke-width="1.5" stroke-dasharray="6,6" />
  </g>

  <!-- BACKGROUND: Layered City Skyline (Siluet Kota) -->
  <g fill="url(#skyline-grad-fallback)">
    <rect x="20" y="180" width="50" height="220" rx="4" opacity="0.3"/>
    <rect x="80" y="140" width="65" height="260" rx="4" opacity="0.3"/>
    <path d="M80 140 L112.5 100 L145 140 Z" opacity="0.3"/>
    <rect x="160" y="200" width="45" height="200" rx="3" opacity="0.3"/>
    <rect x="420" y="160" width="70" height="240" rx="4" opacity="0.3"/>
    <rect x="500" y="210" width="55" height="190" rx="3" opacity="0.3"/>
    
    <!-- Mid buildings -->
    <rect x="45" y="220" width="55" height="180" rx="4" opacity="0.6"/>
    <rect x="120" y="180" width="60" height="220" rx="4" opacity="0.6"/>
    <rect x="380" y="210" width="65" height="190" rx="4" opacity="0.6"/>
    <rect x="465" y="180" width="50" height="220" rx="4" opacity="0.6"/>
    <path d="M465 180 L490 150 L515 180 Z" opacity="0.6"/>
  </g>

  <!-- GROUND LINE -->
  <line x1="0" y1="400" x2="600" y2="400" stroke="#DCE4F0" stroke-width="2" />

  <!-- POTTED PLANT - Left -->
  <g transform="translate(25, 275)" filter="url(#icon-shadow-fallback)">
    <ellipse cx="40" cy="120" rx="20" ry="6" fill="#DCE4F0" />
    <path d="M22 120 L26 145 C27 150, 53 150, 54 145 L58 120 Z" fill="#FFFFFF" stroke="#DCE4F0" stroke-width="1" />
    <path d="M35 120 C10 100, -5 60, 10 40 C20 50, 30 80, 38 100 Z" fill="#3B82F6" opacity="0.8" />
    <path d="M40 120 C35 80, 25 30, 40 15 C50 30, 48 80, 42 100 Z" fill="#0F5FEA" />
    <path d="M45 120 C65 100, 80 60, 68 40 C58 50, 50 80, 43 100 Z" fill="#1D4ED8" opacity="0.75" />
    <path d="M36 120 C25 105, 15 85, 22 75 C30 80, 35 95, 38 110 Z" fill="#93C5FD" />
  </g>

  <!-- LARGE ANALOG CLOCK - Bottom Left -->
  <g transform="translate(100, 320)" filter="url(#soft-shadow-fallback)">
    <circle cx="50" cy="50" r="48" fill="#FFFFFF" stroke="#0F5FEA" stroke-width="4.5" />
    <line x1="50" y1="8" x2="50" y2="13" stroke="#0B1F44" stroke-width="2" />
    <line x1="50" y1="92" x2="50" y2="87" stroke="#0B1F44" stroke-width="2" />
    <line x1="8" y1="50" x2="13" y2="50" stroke="#0B1F44" stroke-width="2" />
    <line x1="92" y1="50" x2="87" y2="50" stroke="#0B1F44" stroke-width="2" />
    <!-- Hands pointing to 09:30 -->
    <line x1="50" y1="50" x2="32" y2="50" stroke="#0B1F44" stroke-width="4.5" stroke-linecap="round" />
    <line x1="50" y1="50" x2="50" y2="82" stroke="#0F5FEA" stroke-width="3" stroke-linecap="round" />
    <circle cx="50" cy="50" r="4.5" fill="#0B1F44" />
  </g>

  <!-- CENTRAL SMARTPHONE -->
  <g transform="translate(210, 130)" filter="url(#soft-shadow-fallback)">
    <rect x="0" y="0" width="140" height="280" rx="18" fill="#000000" />
    <rect x="4" y="4" width="132" height="272" rx="14" fill="url(#phone-screen-fallback)" />
    <rect x="45" y="4" width="50" height="12" rx="6" fill="#000000" />
    <text x="20" y="14" font-family="'Inter', sans-serif" font-size="7" font-weight="700" fill="#000000">09:30</text>
    <g transform="translate(110, 8)" opacity="0.8">
      <rect x="8" y="1" width="10" height="5" rx="1" fill="none" stroke="#000000" stroke-width="0.8" />
      <rect x="9" y="2" width="6" height="3" fill="#000000" />
      <circle cx="1" cy="5" r="0.8" fill="#000000" />
      <circle cx="3.5" cy="4" r="0.8" fill="#000000" />
      <circle cx="6" cy="3" r="0.8" fill="#000000" />
    </g>
    
    <text x="70" y="45" font-family="'Inter', sans-serif" font-size="8" font-weight="600" text-anchor="middle" fill="#66738D">Check-in Berhasil</text>
    
    <g transform="translate(50, 60)">
      <circle cx="20" cy="20" r="18" fill="#0F5FEA" />
      <path d="M12 20 L17 25 L28 14" fill="none" stroke="#FFFFFF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
    </g>

    <text x="70" y="125" font-family="'Inter', sans-serif" font-size="20" font-weight="700" text-anchor="middle" fill="#0B1F44">09:30</text>
    <text x="70" y="138" font-family="'Inter', sans-serif" font-size="7" font-weight="500" text-anchor="middle" fill="#66738D">Senin, 20 Mei 2024</text>
    <line x1="20" y1="155" x2="120" y2="155" stroke="#E2EDFD" stroke-width="1" />

    <g transform="translate(25, 170)">
      <rect x="0" y="0" width="90" height="20" rx="10" fill="#EEF5FF" />
      <path d="M18 6 C15.8 6 14 7.8 14 10 C14 13 18 16 18 16 C18 16 22 13 22 10 C22 7.8 20.2 6 18 6 Z" fill="#0F5FEA" transform="scale(0.8) translate(3, 1)" />
      <circle cx="14.4" cy="8" r="1.5" fill="#FFFFFF" />
      <text x="32" y="13" font-family="'Inter', sans-serif" font-size="7" font-weight="600" fill="#0F5FEA">Kantor Pusat</text>
    </g>
  </g>

  <!-- STANDING EMPLOYEE CHARACTER -->
  <g transform="translate(330, 150)">
    <ellipse cx="45" cy="250" rx="30" ry="6" fill="#DCE4F0" opacity="0.8" />
    <rect x="32" y="170" width="10" height="80" rx="2" fill="#0B1F44" />
    <rect x="48" y="170" width="10" height="80" rx="2" fill="#0B1F44" />
    <path d="M30 248 C30 244, 42 244, 42 250 H32 Z" fill="#000000" />
    <path d="M46 248 C46 244, 58 244, 58 250 H48 Z" fill="#000000" />
    <path d="M25 80 C25 68, 65 68, 65 80 L68 170 C68 172, 22 172, 22 170 Z" fill="#0F5FEA" />
    <rect x="41" y="56" width="8" height="12" fill="#FDBA74" />
    <circle cx="45" cy="46" r="14" fill="#FDBA74" />
    <path d="M31 42 C31 30, 59 30, 59 42 C59 32, 45 28, 31 42 Z" fill="#1E293B" />
    <circle cx="41" cy="45" r="1.5" fill="#1E293B" />
    <circle cx="49" cy="45" r="1.5" fill="#1E293B" />
    <path d="M42 51 Q45 55 48 51" fill="none" stroke="#1E293B" stroke-width="1.5" stroke-linecap="round" />
    <path d="M25 80 L12 110 L20 120 L30 90 Z" fill="#0F5FEA" />
    <circle cx="12" cy="115" r="6" fill="#FDBA74" />
    <rect x="6" y="103" width="10" height="18" rx="2" fill="#1E293B" transform="rotate(-10, 11, 112)" />
    <rect x="8" y="105" width="6" height="14" rx="1" fill="#FFFFFF" transform="rotate(-10, 11, 112)" />
    <path d="M65 80 L73 120 L65 145 L58 145 L62 110 L58 90 Z" fill="#0F5FEA" />
  </g>

  <!-- FEATURES CIRCLES (Lokasi, Foto, Waktu, Kehadiran) -->
  <g transform="translate(140, 95)" filter="url(#icon-shadow-fallback)">
    <circle cx="24" cy="24" r="22" fill="#FFFFFF" stroke="#EEF5FF" stroke-width="1" />
    <path d="M24 12 C19.5 12 16 15.5 16 20 C16 26 24 32 24 32 C24 32 32 26 32 20 C32 15.5 28.5 12 24 12 Z" fill="#0F5FEA" />
    <circle cx="24" cy="20" r="3.5" fill="#FFFFFF" />
    <text x="24" y="58" font-family="'Inter', sans-serif" font-size="8" font-weight="600" text-anchor="middle" fill="#66738D">Lokasi</text>
  </g>

  <g transform="translate(370, 95)" filter="url(#icon-shadow-fallback)">
    <circle cx="24" cy="24" r="22" fill="#FFFFFF" stroke="#EEF5FF" stroke-width="1" />
    <path d="M14 18 C14 16.9 14.9 16 16 16 H20 L22 13 H26 L28 16 H32 C33.1 16 34 16.9 34 18 V30 C34 31.1 33.1 32 32 32 H16 C14.9 32 14 31.1 14 30 Z" fill="#0F5FEA" />
    <circle cx="24" cy="24" r="4.5" fill="#FFFFFF" />
    <circle cx="24" cy="24" r="2.5" fill="#0F5FEA" />
    <text x="24" y="58" font-family="'Inter', sans-serif" font-size="8" font-weight="600" text-anchor="middle" fill="#66738D">Foto</text>
  </g>

  <g transform="translate(110, 205)" filter="url(#icon-shadow-fallback)">
    <circle cx="24" cy="24" r="22" fill="#FFFFFF" stroke="#EEF5FF" stroke-width="1" />
    <circle cx="24" cy="24" r="10" fill="none" stroke="#0F5FEA" stroke-width="2.5" />
    <line x1="24" y1="24" x2="24" y2="18" stroke="#0F5FEA" stroke-width="2.5" stroke-linecap="round" />
    <line x1="24" y1="24" x2="29" y2="24" stroke="#0F5FEA" stroke-width="2" stroke-linecap="round" />
    <text x="24" y="58" font-family="'Inter', sans-serif" font-size="8" font-weight="600" text-anchor="middle" fill="#66738D">Waktu</text>
  </g>

  <g transform="translate(415, 205)" filter="url(#icon-shadow-fallback)">
    <circle cx="24" cy="24" r="22" fill="#FFFFFF" stroke="#EEF5FF" stroke-width="1" />
    <path d="M24 20 C26.2 20 28 18.2 28 16 C28 13.8 26.2 12 24 12 C21.8 12 20 13.8 20 16 C20 18.2 21.8 20 24 20 Z" fill="#0F5FEA" />
    <path d="M16 28 C16 23.6 19.6 22 24 22 C28.4 22 32 23.6 32 28 V30 H16 V28 Z" fill="#0F5FEA" />
    <text x="24" y="58" font-family="'Inter', sans-serif" font-size="8" font-weight="600" text-anchor="middle" fill="#66738D">Kehadiran</text>
  </g>

</svg>
